#Ex-5

pipeline {
    agent any

    stages {
        stage('git checkout') {
            steps {
               git branch: 'main', url: 'https://github.com/CloudTechDevOps/Terraform-0730am.git'
            }
        }
         stage('init') {
            steps {
                dir('Day-1-Terraform-basic-config') {
                  sh  'terraform init'
              
                }
            }
        }
        stage('plan') {
            steps {
                dir('Day-1-Terraform-basic-config') {
                  sh  'terraform plan'
              
                }
            }
        }

        stage ('approve plan') {
            steps {
                input 'Do you want to apply the changes?'
            }
        }

        stage('apply') {
            steps {
                dir('Day-1-Terraform-basic-config') {
                  sh  'terraform apply -auto-approve'
              
                }
            }
        }
      
    }
}




